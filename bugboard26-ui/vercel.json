{
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "ngrok-skip-browser-warning", "value": "true" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://posticteric-tonnishly-leonida.ngrok-free.dev/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
